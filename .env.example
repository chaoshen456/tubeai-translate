# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter API (for GPT translation)
# Get from https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Override default model
# OPENROUTER_MODEL=openai/gpt-4.1-mini

# Optional: Site info for OpenRouter rankings
# SITE_URL=https://your-site.com

# YouTube Data API v3
# Get from https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your-youtube-api-key

# Cron secret for scheduler authentication
CRON_SECRET=your-secure-random-secret-here

# Optional: Region for popular videos (default: US)
# YOUTUBE_REGION=US